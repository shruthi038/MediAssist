# ============================================================
#  MediAssist — .gitignore
#  Covers: Python (FastAPI), Node.js (React/Vite), Docker,
#          environment files, OS artifacts
# ============================================================

# ─── Python ──────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.Python
env/
venv/
.venv/
ENV/
pip-log.txt
pip-delete-this-directory.txt

# ─── Node / Frontend ─────────────────────────────────────────
node_modules/
dist/
.cache/
.parcel-cache/
*.tsbuildinfo
.next/
out/

# ─── Environment & Secrets ───────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key

# ─── Docker ──────────────────────────────────────────────────
*.log
docker-compose.override.yml

# ─── Testing & Coverage ──────────────────────────────────────
.coverage
htmlcov/
.pytest_cache/
coverage/
*.lcov

# ─── IDEs & Editors ──────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*.suo
*.user
*.DS_Store
Thumbs.db

# ─── OS ──────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Desktop.ini

# ─── Uploads / Local Assets ──────────────────────────────────
uploads/
*.tmp

# ─── Alembic / DB Migrations (autogenerated) ─────────────────
# Keep migration scripts; ignore local SQLite test DBs
*.db
*.sqlite3
